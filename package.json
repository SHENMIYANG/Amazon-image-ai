{
  "name": "amazon-image-studio",
  "version": "1.0.0",
  "description": "亚马逊电商图片 AI 生成工具 - 基于 GPT-Image-2 自动生成高质量商品主图和 A+ 页面图片",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "install:all": "npm ci && cd frontend && npm ci && cd ../backend && npm ci --production"
  },
  "keywords": [
    "amazon",
    "ecommerce",
    "image-generation",
    "ai",
    "gpt-image-2",
    "openai"
  ],
  "author": "SHENMIYANG",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SHENMIYANG/Amazon-image-ai.git"
  },
  "bugs": {
    "url": "https://github.com/SHENMIYANG/Amazon-image-ai/issues"
  },
  "homepage": "https://github.com/SHENMIYANG/Amazon-image-ai#readme"
}
